package.json
package-lock.json
pnpm-lock.yaml
vite.config.ts
tsconfig.json
types.d.ts
.npmrc
vite.generated.ts
bundles/

# Vaadin dev-mode runtime cache
.vaadin/

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
.env.*

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
