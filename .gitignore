target/
*.class
*.jar

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.eclipse/
.settings/
.classpath
.project

# ── Vaadin — all auto-generated by prepare-frontend / build-frontend ─────────
